function Home() {
  const navigate = useNavigate();
  const userName = localStorage.getItem("userName") || "Knight";

  function handleLogout() {
    localStorage.removeItem("isLoggedIn");
    localStorage.removeItem("userName");
    localStorage.removeItem("userEmail");

    navigate("/login");
  }

  function handleSearch(event) {
    event.preventDefault();
    navigate("/listings");
  }

  function handleCategoryClick(categoryName) {
    navigate(`/listings?category=${encodeURIComponent(categoryName)}`);
  }

  return (
    <div className="home-page">
      <header className="main-header">
        <div className="brand-area">
          <div className="brand-shield">♞</div>

          <div>
            <h1 className="brand-name">
              Knight<span>Market</span>
            </h1>

            <p className="brand-tagline">BUY. SELL. CONNECT.</p>
          </div>
        </div>

        <nav className="main-nav" aria-label="Main navigation">
          <a href="#home" className="active">
            Home
          </a>

          <button type="button" onClick={() => navigate("/listings")}>
            Listings
          </button>

          <button type="button" onClick={() => navigate("/messages")}>
            Messages
          </button>

          <button type="button" onClick={() => navigate("/my-listings")}>
            My Listings
          </button>

          <a href="#how-it-works">How It Works</a>
          <a href="#about">About Us</a>
        </nav>

        <div className="header-actions">
          <button
            type="button"
            className="notification-button"
            onClick={() => navigate("/notifications")}
            aria-label="Notifications"
          >
            ♧
            <span className="notification-count">2</span>
          </button>

          <div className="profile-menu">
            <button type="button" className="profile-button">
              <span className="profile-avatar">
                {userName.charAt(0).toUpperCase()}
              </span>

              <span>{userName}</span>
              <span className="profile-arrow">⌄</span>
            </button>

            <div className="profile-dropdown">
              <button type="button" onClick={() => navigate("/profile")}>
                My Profile
              </button>

              <button type="button" onClick={() => navigate("/my-listings")}>
                My Listings
              </button>

              <button type="button" onClick={() => navigate("/saved")}>
                Saved Items
              </button>

              <button type="button" onClick={() => navigate("/messages")}>
                Messages
              </button>

              <button
                type="button"
                className="logout-button"
                onClick={handleLogout}
              >
                Sign Out
              </button>
            </div>
          </div>
        </div>
      </header>

      <main>
        <section className="hero-section" id="home">
          <div className="hero-content">
            <p className="hero-kicker">UCF STUDENT MARKETPLACE</p>

            <h2>
              The UCF Marketplace
              <span>Built by Knights, for Knights.</span>
            </h2>

            <p className="hero-description">
              Buy, sell, and connect with fellow UCF students.
              Trusted, secure, and student-powered.
            </p>

            <form className="hero-search" onSubmit={handleSearch}>
              <span className="search-icon">⌕</span>

              <input
                type="search"
                placeholder="Search textbooks, electronics, furniture, and more..."
                aria-label="Search marketplace listings"
              />

              <button type="submit">Search</button>
            </form>

            <div className="trending-searches">
              <strong>Trending:</strong>
              <button type="button">MacBook</button>
              <button type="button">Mini Fridge</button>
              <button type="button">Desk</button>
              <button type="button">Textbooks</button>
            </div>

            <div className="hero-buttons">
              <button
                type="button"
                className="primary-action"
                onClick={() => navigate("/listings")}
              >
                Browse All Items
              </button>

              <button
                type="button"
                className="secondary-action"
                onClick={() => navigate("/post-item")}
              >
                Post an Item
              </button>
            </div>
          </div>

          <div className="hero-image-placeholder">
            <div className="image-placeholder-content">
              <span>Campus image coming soon</span>
              <small>A student can add the final UCF image later</small>
            </div>
          </div>
        </section>

        {/* ===============================
            EXPLORE CATEGORIES
        =============================== */}

        <section className="categories-section">

          <div className="section-title">

            <h2>Explore Categories</h2>

            <p>
              Find exactly what you're looking for across KnightMarket.
            </p>

          </div>

          <div className="categories-grid">

            {categories.map((category) => (

              <button
                key={category.id}
                className="category-card"
                onClick={() => handleCategoryClick(category.title)}
              >

                <div className="category-icon">
                  {category.icon}
                </div>

                <h3>{category.title}</h3>

                <span>{category.count}</span>

              </button>

            ))}

          </div>

        </section>

        {/* ===============================
            FEATURED LISTINGS
        =============================== */}

        <section className="marketplace-content">

          <div className="featured-section">

            <div className="section-heading">

              <h2>Featured Listings</h2>

              <button
                className="view-all-button"
                onClick={() => navigate("/listings")}
              >
                View All →
              </button>

            </div>

            <div className="featured-grid">

              {featuredListings.map((listing) => (

                <article
                  className="listing-card"
                  key={listing.id}
                >

                  <div className="listing-image-wrapper">

                    <img
                      src={listing.image}
                      alt={listing.title}
                    />

                    <button className="favorite-button">
                      ♡
                    </button>

                  </div>

                  <div className="listing-card-content">

                    <h3>{listing.title}</h3>

                    <p className="listing-price">
                      {listing.price}
                    </p>

                    <div className="listing-meta">

                      <span>{listing.location}</span>

                      <span>{listing.time}</span>

                    </div>

                  </div>

                </article>

              ))}

            </div>

          </div>

          <aside className="recent-section">

            <div className="section-heading">

              <h2>Recently Posted</h2>

            </div>

            <div className="recent-list">

              {recentListings.map((listing) => (

                <article
                  key={listing.id}
                  className="recent-item"
                >

                  <img
                    src={listing.image}
                    alt={listing.title}
                  />

                  <div className="recent-item-info">

                    <h3>{listing.title}</h3>

                    <p>{listing.price}</p>

                  </div>

                  <span className="recent-time">
                    {listing.time}
                  </span>

                </article>

              ))}

            </div>

          </aside>

        </section>
